	vector& operator=(const vector& other) {
		if (this != &other) {
			if (other.size_val > capacity_val) {
				reserve(other.capacity_val);
			}
			clear();
			for (size_t i = 0; i < other.size_val; ++i) {
				new (data + i) T(other.data[i]);
			}
			size_val = other.size_val;
		}
		return *this;
	}
