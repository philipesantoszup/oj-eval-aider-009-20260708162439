	iterator erase(iterator pos) {
		size_t index = pos.ptr - data;
		if (index >= size_val) throw index_out_of_bound();

		for (size_t i = index; i < size_val - 1; ++i) {
			new (data + i) T(std::move(data[i + 1]));
			data[i + 1].~T();
		}
		data[size_val - 1].~T();
		size_val--;
		return iterator(data + index);
	}
